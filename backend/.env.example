PORT=5000
NODE_ENV=development

# MongoDB (local or MongoDB Atlas)
MONGODB_URI=mongodb://0.0.0.0/softsync

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Frontend URL for CORS (your Hostinger domain)
FRONTEND_URL=https://soft-sync-frontend.vercel.app/

# Public API URL (used for uploaded image URLs)
API_PUBLIC_URL=https://softsync-backend.onrender.com/

# First admin account (run npm run seed once)
ADMIN_EMAIL=admin@softsync.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=SoftSync Admin
